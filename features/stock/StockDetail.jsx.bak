const TECH_DATA = {
  "2222":{ m5:"شراء قوي",m15:"شراء",m30:"شراء قوي",h1:"شراء",h5:"شراء",d1:"شراء قوي",w1:"شراء",mo1:"شراء",priceScore:72,maBuy:4,maSell:2,indBuy:3,indSell:2 },
